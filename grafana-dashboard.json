{
  "title": "L3MON Metrics",
  "panels": [
    {
      "type": "graph",
      "title": "Requests per second",
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Active Users",
      "targets": [
        {
          "expr": "active_users"
        }
      ]
    }
  ]
}
